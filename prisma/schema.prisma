generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COUNSELLOR
  TRAINER
}

enum MemberStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum PackageType {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum PhysicalActivityLevel {
  MILD
  MODERATE
  HEAVY
}

enum StressLevel {
  MILD
  MODERATE
  HEAVY
}

enum SleepQuality {
  SOUND
  DISTURBED
  FAIR
  BAD
}

enum MedicalConditionName {
  CHRONIC_ILLNESS
  RECENT_SURGERY
  PREGNANCY
  BREASTFEEDING
  BREATHING_LUNG
  MUSCULOSKELETAL_INJURY
  ARTHRITIS
  DIABETES
  THYROID
  OBESITY
  HIGH_CHOLESTEROL
  FAMILY_HEART_HISTORY
  HERNIA
  FREQUENT_HEADACHES
  FREQUENT_RESPIRATORY
  DEPRESSION_BIPOLAR_SAD
  CIRCULATORY
  DIGESTIVE
  OTHER
}

// ---- Core Tables ----

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          Role     @default(TRAINER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  counsellorMembers Member[]  @relation("CounsellorMembers")
  trainerMembers    Member[]  @relation("TrainerMembers")
  counsellingNotes  CounsellingNote[]
  auditLogs         AuditLog[]

  parQAssessments      PARQ[]             @relation("AssessorPARQ")
  lifestyleProfiles    LifestyleProfile[] @relation("AssessorLifestyle")
  medicalAssessments   MedicalCondition[] @relation("AssessorMedical")
  menstrualAssessments MenstrualHistory[] @relation("AssessorMenstrual")
  posturalAssessments  PosturalAnalysis[] @relation("AssessorPostural")
  fitnessAssessments   FitnessTest[]      @relation("AssessorFitness")
  uploadedDocuments    Document[]         @relation("UploaderDocuments")
}

model Member {
  id              String       @id @default(cuid())
  membershipNo    String       @unique
  receiptNo       String?
  date            DateTime     @default(now())
  fullName        String
  gender          Gender
  dateOfBirth     DateTime
  age             Int?         // auto-calculated on write
  mobile          String       @unique
  email           String?      @unique
  address         String?
  maritalStatus   MaritalStatus?
  status          MemberStatus @default(ACTIVE)

  // Membership
  package         PackageType
  durationMonths  Int
  startDate       DateTime
  endDate         DateTime
  counsellorId    String?
  counsellor      User?         @relation("CounsellorMembers", fields: [counsellorId], references: [id])
  trainerId       String?
  trainer         User?         @relation("TrainerMembers", fields: [trainerId], references: [id])

  // Fitness goals (bitmask or separate table)
  fitnessGoals    FitnessGoal[]

  // Related assessments
  parQAssessments     PARQ[]             @relation("MemberPARQ")
  lifestyleProfiles   LifestyleProfile[] @relation("MemberLifestyle")
  medicalConditions MedicalCondition[]
  menstrualHistories  MenstrualHistory[] @relation("MemberMenstrual")
  posturalAnalyses    PosturalAnalysis[] @relation("MemberPostural")
  fitnessTests        FitnessTest[]      @relation("MemberFitness")
  measurements        Measurement[]
  counsellingNotes CounsellingNote[]
  documents        Document[]
  consent          Consent?

  archivedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
  @@index([fullName])
  @@index([counsellorId])
  @@index([trainerId])
}

model FitnessGoal {
  id       String   @id @default(cuid())
  memberId String
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  goal     String   // Weight Loss, Weight Gain, etc.

  @@unique([memberId, goal])
}

model PARQ {
  id       String  @id @default(cuid())
  memberId String
  member   Member  @relation("MemberPARQ", fields: [memberId], references: [id], onDelete: Cascade)

  assessedAt               DateTime  @default(now())
  assessorId               String?
  assessor                 User?     @relation("AssessorPARQ", fields: [assessorId], references: [id])

  q1_heartTrouble          Boolean   @default(false)
  q2_chestPain             Boolean   @default(false)
  q3_dizzinessFainting     Boolean   @default(false)
  q4_highBloodPressure     Boolean   @default(false)
  q5_boneJointProblems     Boolean   @default(false)
  q6_otherReasons          Boolean   @default(false)
  q7_over45Unaccustomed    Boolean   @default(false)

  medicalClearanceRequired Boolean   @default(false)
  notes                    String?   @db.Text

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([memberId])
  @@index([assessedAt])
}

model LifestyleProfile {
  id       String  @id @default(cuid())
  memberId String
  member   Member  @relation("MemberLifestyle", fields: [memberId], references: [id], onDelete: Cascade)

  assessedAt              DateTime               @default(now())
  assessorId              String?
  assessor                User?                  @relation("AssessorLifestyle", fields: [assessorId], references: [id])

  occupation              String?
  physicalActivityLevel   PhysicalActivityLevel?
  workStress              StressLevel?
  personalStress          StressLevel?
  travelFrequency         String?

  avgSleepHours           Float?
  sleepQuality            SleepQuality?
  sleepTiming             String?
  afternoonNap            Boolean?
  napDuration             String?

  smoking                 Boolean?
  smokingFrequency        String?
  alcohol                 Boolean?
  alcoholFrequency        String?
  tobacco                 Boolean?
  tobaccoFrequency        String?

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([memberId])
  @@index([assessedAt])
}

model MedicalCondition {
  id            String               @id @default(cuid())
  memberId      String
  member        Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)

  assessedAt    DateTime             @default(now())
  assessorId    String?
  assessor      User?                @relation("AssessorMedical", fields: [assessorId], references: [id])

  conditionName MedicalConditionName
  customName    String?
  details       String?              @db.Text
  notes         String?              @db.Text

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([memberId, conditionName, assessedAt])
  @@index([memberId])
}

model MenstrualHistory {
  id       String  @id @default(cuid())
  memberId String
  member   Member  @relation("MemberMenstrual", fields: [memberId], references: [id], onDelete: Cascade)

  assessedAt               DateTime  @default(now())
  assessorId               String?
  assessor                 User?     @relation("AssessorMenstrual", fields: [assessorId], references: [id])

  lastCycleDate            DateTime?
  ageAtMenstruationOnset   Int?
  averageCycleLength       Int?
  irregularCycles          Boolean?
  spotting                 Boolean?
  missedCycles             Boolean?
  painfulMenstruation      Boolean?
  notes                    String?   @db.Text

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([memberId])
  @@index([assessedAt])
}

model PosturalAnalysis {
  id                    String @id @default(cuid())
  memberId              String
  member                Member @relation("MemberPostural", fields: [memberId], references: [id], onDelete: Cascade)

  assessedAt            DateTime @default(now())
  assessorId            String?
  assessor              User?    @relation("AssessorPostural", fields: [assessorId], references: [id])

  neckFlexion           String?
  neckLateralFlexion    String?
  pokeChin              String?
  neckLateralRotation   String?

  spineKyphosis         String?
  spineLordosis         String?
  spineScoliosis        String?
  spineKyphoscoliosis   String?

  scapulaLeft           String?   // Normal, Protracted, Elevated, Winging
  scapulaRight          String?

  lphcAsymmetrical      Boolean?

  kneeLeft              String?   // Genu Valgum, Genu Varum
  kneeRight             String?

  footLeft              String?   // Flat Foot, Normal, Inversion, Eversion
  footRight             String?

  symmetryDeviation     String?
  trainerNotes          String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([memberId])
  @@index([assessedAt])
}

model FitnessTest {
  id                  String @id @default(cuid())
  memberId            String
  member              Member @relation("MemberFitness", fields: [memberId], references: [id], onDelete: Cascade)
  testDate            DateTime @default(now())
  assessorId          String?
  assessor            User?    @relation("AssessorFitness", fields: [assessorId], references: [id])

  // Cardiovascular
  cardioMachine       String?
  distance            Float?
  durationMinutes     Int?
  treadmillNotes      String?

  // Muscular Endurance
  wallPushUpsReps     Int?
  wallPushUpsDurationSec Int?
  squatsReps          Int?
  squatsDurationSec   Int?
  crunchesReps        Int?
  crunchesDurationSec Int?

  // Flexibility
  sitAndReachCm       Float?

  // Core Endurance
  ironManHoldSec      Int?
  pelvicBridgeSec     Int?

  // Balance (Left / Right)
  rProprioception     String?
  rSingleLegStanding  String?
  rStandingBalance    String?
  lProprioception     String?
  lSingleLegStanding  String?
  lStandingBalance    String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([memberId])
  @@index([testDate])
}

model Measurement {
  id              String @id @default(cuid())
  memberId        String
  member          Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  measuredAt      DateTime @default(now())

  // Body Composition
  heightCm        Float?
  weightKg        Float?
  bmi             Float?   // auto-calculated
  bodyFatPercent  Float?
  visceralFat     Float?
  bmr             Float?
  biologicalAge   Int?

  // Frame
  shoulderWidth   Float? // bi-acromial
  hipWidth        Float? // bi-iliac

  // Circumferences
  neckCirc        Float?
  shoulderCirc    Float?
  chestNormal     Float?
  chestExpansion  Float?
  armCirc         Float?
  forearmCirc     Float?
  abdomenCirc     Float?
  waistCirc       Float?
  hipCirc         Float?
  midThighCirc    Float?
  calfCirc        Float?

  waistHipRatio   Float? // auto-calculated (waist/hip)
  ratioIndicator  String? // "Healthy" / "Needs Attention"

  createdAt       DateTime @default(now())
}

model CounsellingNote {
  id          String @id @default(cuid())
  memberId    String
  member      Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  authorId    String
  author      User   @relation(fields: [authorId], references: [id])
  noteType    String // Fitness Counselling, Training Note, etc.
  description String
  createdAt   DateTime @default(now())
}

model Document {
  id          String @id @default(cuid())
  memberId    String
  member      Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  fileType    String   // "pdf", "image", etc.
  category    String?  // Medical, Lab, Diet, Photo, Consent
  uploadedAt  DateTime @default(now())
  uploaderId  String
  uploader    User   @relation("UploaderDocuments", fields: [uploaderId], references: [id])
}

model Consent {
  id                  String @id @default(cuid())
  memberId            String @unique
  member              Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  emergencyContactName String?
  emergencyMobile     String?
  relationship        String?
  consentDate         DateTime @default(now())
  digitalSignature    String? // base64 image
  createdAt           DateTime @default(now())
}

model AuditLog {
  id          String @id @default(cuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id])
  action      String // "CREATE_MEMBER", "ARCHIVE_MEMBER", etc.
  entityType  String // "Member", "Measurement"
  entityId    String
  details     Json?
  createdAt   DateTime @default(now())
}